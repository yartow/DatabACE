library(sqldf)
sqldf(
"
select
p.CallName, p.Surname,
g.Date,
g.Course,
g.Pace_ID,
g.Type,
g.Grade,
d.Term,
c.Alias,
-- pace.StarValue,
pace.Number
from Grade g
join Person p
on g.StudentID = p.ID
join Date d
on g.Date = d.Date
join PaceCourse pc
on g.Course = pc.courseID
and g.Pace_ID = pc.paceID
join PACE pace
on pc.paceID = pace.ID
join Course c
on c.ID = pc.courseID
"
) %>%
as_tibble
